<mxfile host="app.diagrams.net">
  <diagram name="Car Selector Architecture v2">
    <mxGraphModel dx="1300" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="fe" value="FRONTEND" style="swimlane;html=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="300" height="400" as="geometry"/>
        </mxCell>

        <mxCell id="react" value="React" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="fe">
          <mxGeometry x="50" y="70" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="vue" value="Vue.js" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="fe">
          <mxGeometry x="50" y="170" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="ui" value="Car Selector UI Chat Interface Filters Results" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="fe">
          <mxGeometry x="50" y="270" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="be" value="BACKEND" style="swimlane;html=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="420" y="40" width="700" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="fastapi" value="FastAPI (Python)&#10;REST API&#10;Business Logic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="be">
          <mxGeometry x="40" y="70" width="220" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="rec" value="Recommendation Engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="be">
          <mxGeometry x="40" y="220" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="claude" value="Claude AI API&#10;Requirement Extraction&#10;Recommendation Explanations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="be">
          <mxGeometry x="360" y="70" width="260" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="db" value="PostgreSQL&#10;Cars&#10;Specifications&#10;Pricing" style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="be">
          <mxGeometry x="380" y="250" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="scraper" value="Web Scraping Service (Python)&#10;Manufacturer Sites&#10;Dealer Portals&#10;Price Lists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="be">
          <mxGeometry x="360" y="390" width="260" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="fe" target="fastapi"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="be" source="fastapi" target="rec"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" parent="be" source="fastapi" target="claude"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" parent="be" source="rec" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" edge="1" parent="be" source="scraper" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>